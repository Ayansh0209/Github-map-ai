# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example  —  copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────────────
PORT=5000
REDIS_URL=redis://default:password@host:6379
GITHUB_TOKEN=ghp_your_github_token

# ── Object storage (the permanent fix for Redis OOM) ─────────────────────────
# Works with ANY S3-compatible provider. Set credentials + bucket + EITHER
# R2_ENDPOINT (any provider) OR R2_ACCOUNT_ID (Cloudflare R2 only). When set,
# large graph artifacts go to object storage instead of Redis. Leave blank for
# local dev (falls back to gzipped Redis). Switching providers later = env only.
#
#   Cloudflare R2 : set R2_ACCOUNT_ID (no R2_ENDPOINT needed), region "auto".
#   Backblaze B2  : R2_ENDPOINT=https://s3.us-east-005.backblazeb2.com  R2_REGION=us-east-005
#   Supabase      : R2_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3  R2_REGION=<project region>
#   Storj/Wasabi  : use the provider's S3 endpoint + region.
R2_ACCESS_KEY_ID=               # provider access key id
R2_SECRET_ACCESS_KEY=           # provider secret access key (shown once)
R2_BUCKET_NAME=                 # bucket name, e.g. github-map-artifacts
R2_ENDPOINT=                    # S3 endpoint URL (B2/Supabase/Storj/Wasabi). Leave blank for R2.
R2_REGION=                      # region; blank = "auto" (R2). B2/Supabase need a real region.
R2_ACCOUNT_ID=                  # Cloudflare R2 only (account id from R2 dashboard)
R2_PUBLIC_URL=                  # optional: only if you enable public bucket access



# ── Queue tuning (safe defaults — override only if needed) ───────────────────
MAX_CONCURRENT_JOBS=1
MAX_QUEUE_SIZE=100
JOB_TIMEOUT_MS=600000
LOCK_DURATION_MS=120000
STALLED_INTERVAL_MS=60000
MAX_STALLED_COUNT=2
PARSE_CHUNK_SIZE=20

# ── Artifact / cache TTLs (seconds) ──────────────────────────────────────────
ARTIFACT_TTL_SECONDS=604800     # 7 days  (Redis-fallback artifacts, indexes)
CHECKPOINT_TTL_SECONDS=7200     # 2 hours (resumable parse checkpoints)
RESULT_TTL_SECONDS=604800       # 7 days  (cached final result by SHA)

# ── Optional integrations ────────────────────────────────────────────────────
GEMINI_API_KEY=
ENABLE_ITERATIVE_CHAT_RETRIEVAL=false
GCP_PROJECT_ID=
GCP_LOCATION=
