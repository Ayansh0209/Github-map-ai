# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example  —  copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────────────
PORT=5000
REDIS_URL=redis://default:password@host:6379
GITHUB_TOKEN=ghp_your_github_token

# ── Cloudflare R2 (the permanent fix for Redis OOM) ──────────────────────────
# When ALL FOUR of the values below are set, large graph artifacts go to R2
# instead of Redis. Leave them blank for local dev (falls back to gzipped Redis).
# See the setup steps in the chat / DEPLOY.md for how to obtain each value.
R2_ACCOUNT_ID=                  # Cloudflare account ID (R2 dashboard, right sidebar)
R2_ACCESS_KEY_ID=               # from R2 → Manage API Tokens → Create (Object R/W)
R2_SECRET_ACCESS_KEY=           # shown ONCE when you create the API token
R2_BUCKET_NAME=                 # the bucket you create, e.g. github-map-artifacts
R2_PUBLIC_URL=                  # optional: public bucket URL, only if you enable public access

# ── Queue tuning (safe defaults — override only if needed) ───────────────────
MAX_CONCURRENT_JOBS=1
MAX_QUEUE_SIZE=100
JOB_TIMEOUT_MS=600000
LOCK_DURATION_MS=120000
STALLED_INTERVAL_MS=60000
MAX_STALLED_COUNT=2
PARSE_CHUNK_SIZE=20

# ── Artifact / cache TTLs (seconds) ──────────────────────────────────────────
ARTIFACT_TTL_SECONDS=604800     # 7 days  (Redis-fallback artifacts, indexes)
CHECKPOINT_TTL_SECONDS=7200     # 2 hours (resumable parse checkpoints)
RESULT_TTL_SECONDS=604800       # 7 days  (cached final result by SHA)

# ── Optional integrations ────────────────────────────────────────────────────
GEMINI_API_KEY=
ENABLE_ITERATIVE_CHAT_RETRIEVAL=false
GCP_PROJECT_ID=
GCP_LOCATION=
